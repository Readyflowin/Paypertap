{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },

  "exclude": ["node_modules", "dist"]
}